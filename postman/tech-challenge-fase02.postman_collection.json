              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente Demonstração\",\n  \"email\": \"{{emailDemo}}\",\n  \"login\": \"{{loginDemo}}\",\n  \"senha\": \"{{senha}}\",\n  \"endereco\": {\n    \"rua\": \"Rua das Flores\",\n    \"numero\": \"123\",\n    \"cidade\": \"São Paulo\",\n    \"cep\": \"01310100\"\n  },\n  \"tipoUsuarioId\": \"{{tipoClienteId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/usuarios", "host": ["{{baseUrl}}"], "path": ["v1", "usuarios"] }
          }
        },
        {
          "name": "Buscar usuário por ID",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/usuarios/{{usuarioDemoId}}", "host": ["{{baseUrl}}"], "path": ["v1", "usuarios", "{{usuarioDemoId}}"] }
          }
        },
        {
          "name": "Buscar usuários por nome (paginado)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/usuarios?nome=Cliente&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "usuarios"],
              "query": [{ "key": "nome", "value": "Cliente" }, { "key": "page", "value": "0" }, { "key": "size", "value": "10" }]
            }
          }
        },
        {
          "name": "Atualizar usuário (parcial)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Cliente Nome Atualizado\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/usuarios/{{usuarioDemoId}}", "host": ["{{baseUrl}}"], "path": ["v1", "usuarios", "{{usuarioDemoId}}"] }
          }
        },
        {
          "name": "Associar tipo de usuário",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('tipo associado', () => pm.expect(pm.response.json().data.tipoUsuarioId).to.eql(pm.collectionVariables.get('tipoUsuarioId')));"] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tipoUsuarioId\": \"{{tipoUsuarioId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/usuarios/{{usuarioDemoId}}/tipo-usuario", "host": ["{{baseUrl}}"], "path": ["v1", "usuarios", "{{usuarioDemoId}}", "tipo-usuario"] }
          }
        },
        {
          "name": "Trocar senha",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"login\": \"{{loginDemo}}\",\n  \"senhaAtual\": \"{{senha}}\",\n  \"novaSenha\": \"novaSenha123\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/usuarios/{{usuarioDemoId}}/senha", "host": ["{{baseUrl}}"], "path": ["v1", "usuarios", "{{usuarioDemoId}}", "senha"] }
          }
        }
      ]
    },
