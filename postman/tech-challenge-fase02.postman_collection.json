    {
      "name": "5. Limpeza (exclusões)",
      "description": "Exclui os recursos criados durante a execução, na ordem correta de dependências (item -> restaurante -> usuários -> tipo de usuário). Permite rodar a coleção inteira repetidamente sem deixar resíduos.",
      "item": [
        {
          "name": "Excluir item de cardápio",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/itens-cardapio/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["v1", "itens-cardapio", "{{itemId}}"] }
          }
        },
        {
          "name": "Excluir restaurante",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/restaurantes/{{restauranteId}}", "host": ["{{baseUrl}}"], "path": ["v1", "restaurantes", "{{restauranteId}}"] }
          }
        },
        {
          "name": "Excluir usuário (demonstração)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/usuarios/{{usuarioDemoId}}", "host": ["{{baseUrl}}"], "path": ["v1", "usuarios", "{{usuarioDemoId}}"] }
          }
        },
        {
          "name": "Excluir usuário (dono/login)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }
          ],
          "request": {
            "method": "DELETE",
